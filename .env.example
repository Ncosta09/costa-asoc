# Dominio público del sitio (sin barra final). Usado para metadata, sitemap, canonicals.
NEXT_PUBLIC_SITE_URL=https://www.costa-asoc.com.ar

# Resend — envío del formulario de contacto
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email que recibe las consultas del formulario
CONTACT_EMAIL_TO=gcosta@costa-asoc.com.ar

# Email "from" verificado en Resend (dominio verificado)
CONTACT_EMAIL_FROM=Costa & Asociados <web@costa-asoc.com.ar>
