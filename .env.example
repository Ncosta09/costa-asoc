# Dominio público del sitio (sin barra final). Usado para metadata, sitemap, canonicals.
NEXT_PUBLIC_SITE_URL=https://www.costa-asoc.com.ar

# Resend — envío del formulario de contacto
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email que recibe las consultas del formulario
CONTACT_EMAIL_TO=gcosta@costa-asoc.com.ar

# Email "from" verificado en Resend (dominio verificado). Formato: Nombre <casilla@dominio>
CONTACT_EMAIL_FROM=Costa & Asociados <web@costa-asoc.com.ar>

# Verificación de propiedad para buscadores (opcional, se cargan en Vercel sin tocar código).
# Google Search Console → método "Etiqueta HTML" → pegar SOLO el valor del content.
GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools → método "meta tag" → valor del content de msvalidate.01
BING_SITE_VERIFICATION=
